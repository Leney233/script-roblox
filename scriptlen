--- Lógica Opción 7 (DETENER SCRIPT) ---
local function enOpcion7Click()
	detenerAutoapuntado()
	
	estaSiguiendo = false
	estaSiguiendoEquipo = false
	if conexionDeSeguimiento then
		conexionDeSeguimiento:Disconnect()
		conexionDeSeguimiento = nil
	end
	if conexionSeguimientoEquipo then
		conexionSeguimientoEquipo:Disconnect()
		conexionSeguimientoEquipo = nil
	end
	
	airJumpActivo = false
	
	-- Limpiar Resaltado
	if resaltarJugadoresActivo then
		resaltarJugadoresActivo = false
		for _, p in pairs(PlayersService:GetPlayers()) do
			if p.Character then
				for _, descendant in pairs(p.Character:GetDescendants()) do
					aplicarResaltado(descendant, false)
				end
			end
		end
	end
	if conexionResaltarPlayerAdded then
		conexionResaltarPlayerAdded:Disconnect()
		conexionResaltarPlayerAdded = nil
	end
	for player, connection in pairs(conexionesResaltarCharAdded) do
		connection:Disconnect()
	end
	conexionesResaltarCharAdded = {}

	-- Limpiar TP Loop
	if conexionTpLoop then
		conexionTpLoop:Disconnect()
		conexionTpLoop = nil
	end
	
	for _, con in ipairs(conexionesActivas) do
		con:Disconnect()
	end
	conexionesActivas = {} 
	
	if screenGui then
		screenGui:Destroy()
	end
	
	screenGui = nil
	menuContent = nil
	toggleButton = nil
	botonOpcion1 = nil
	botonOpcion2 = nil
	botonOpcion3 = nil
	botonOpcion4 = nil
	botonOpcion5 = nil
	botonOpcion6 = nil 
	botonOpcion7 = nil
	tpMenu = nil 
	playerNameBox = nil
	tpButton = nil
	tpLoopButton = nil
end

