local tpLoopActive = false
local conexionTpLoop = nil

-- Función para encontrar un jugador por nombre (parcial y sin mayúsculas)
local function findPlayerByName(name)
	local nameLower = name:lower()
	for _, p in pairs(PlayersService:GetPlayers()) do
		if p ~= player then
			if p.Name:lower():sub(1, #nameLower) == nameLower then
				return p.Character
			end
		end
	end
	return nil
end

