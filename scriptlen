--- NUEVO: Lógica de Resaltar Jugadores (Opción 5) ---
local function actualizarResaltadoJugadores()
	for _, p in pairs(PlayersService:GetPlayers()) do
		if p ~= player then
			local char = p.Character
			if char then
				for _, child in pairs(char:GetChildren()) do
					if child:IsA("BasePart") then
						if resaltarJugadoresActivo then
							local highlight = child:FindFirstChild("PlayerHighlight")
							if not highlight then
								highlight = Instance.new("Highlight")
								highlight.Name = "PlayerHighlight"
								highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- Blanco
								highlight.FillTransparency = 0.5 -- Un poco transparente
								highlight.Parent = child
							end
						else
							local highlight = child:FindFirstChild("PlayerHighlight")
							if highlight then
								highlight:Destroy()
							end
						end
					end
				end
			end
		end
	end
end

local function enOpcion5ClickResaltar() -- Nuevo nombre de función
	resaltarJugadoresActivo = not resaltarJugadoresActivo
	if resaltarJugadoresActivo then
		botonOpcion5.Text = "Resaltar Jugadores: ON"
		botonOpcion5.BackgroundColor3 = Color3.fromRGB(60, 140, 70)
	else
		botonOpcion5.Text = "Resaltar Jugadores"
		botonOpcion5.BackgroundColor3 = Color3.fromRGB(70, 70, 85)
	end
	actualizarResaltadoJugadores() -- Aplicar/quitar el resaltado inmediatamente

	-- También necesitamos un listener para nuevos jugadores o respawns
	if resaltarJugadoresActivo then
		conexionesActivas["PlayerAdded_Resaltar"] = PlayersService.PlayerAdded:Connect(function(newPlayer)
			newPlayer.CharacterAdded:Connect(function(newChar)
				task.wait(0.1) -- Esperar un momento para que carguen las partes
				if resaltarJugadoresActivo then
					for _, child in pairs(newChar:GetChildren()) do
						if child:IsA("BasePart") then
							local highlight = Instance.new("Highlight")
							highlight.Name = "PlayerHighlight"
							highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
							highlight.FillTransparency = 0.5
							highlight.Parent = child
						end
					end
				end
			end)
		end)
	else
		if conexionesActivas["PlayerAdded_Resaltar"] then
			conexionesActivas["PlayerAdded_Resaltar"]:Disconnect()
			conexionesActivas["PlayerAdded_Resaltar"] = nil
		end
	end
end
