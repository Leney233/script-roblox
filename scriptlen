--- MODIFICADO: Lógica de Resaltar Jugadores (Opción 5) ---
-- Esta función aplica/quita el resaltado a UNA parte
local function aplicarResaltado(part, activar)
	if not part or not part:IsA("BasePart") then return end
	
	local highlight = part:FindFirstChild("PlayerHighlight")
	if activar then
		if not highlight then
			highlight = Instance.new("Highlight")
			highlight.Name = "PlayerHighlight"
			highlight.OutlineColor = Color3.fromRGB(255, 255, 255) 
			highlight.FillTransparency = 0.5 
			highlight.Parent = part
		end
	else
		if highlight then
			highlight:Destroy()
		end
	end
end

-- Esta función se llama CADA VEZ que un personaje aparece
local function onCharacterAddedForHighlight(character)
	-- Aplicar a todas las partes que YA existen
	for _, descendant in pairs(character:GetDescendants()) do
		aplicarResaltado(descendant, true)
	end
	
	-- Escuchar por partes que se añaden DESPUÉS (como accesorios o partes que tardan en cargar)
	local conn = character.DescendantAdded:Connect(function(descendant)
		if resaltarJugadoresActivo then
			aplicarResaltado(descendant, true)
		end
	end)
	-- Guardar esta conexión para poder limpiarla después
	conexionesResaltarCharAdded[character] = conn
end

-- Esta función se llama CADA VEZ que un personaje se va
local function onCharacterRemovingForHighlight(character)
	-- Limpiar la conexión de 'DescendantAdded'
	if conexionesResaltarCharAdded[character] then
		conexionesResaltarCharAdded[character]:Disconnect()
		conexionesResaltarCharAdded[character] = nil
	end
end

local function enOpcion5Click()
	resaltarJugadoresActivo = not resaltarJugadoresActivo
	
	if resaltarJugadoresActivo then
		botonOpcion5.Text = "Resaltar: ON"
		botonOpcion5.BackgroundColor3 = Color3.fromRGB(60, 140, 70)

		-- 1. Conectar para jugadores que se unan *después*
		conexionResaltarPlayerAdded = PlayersService.PlayerAdded:Connect(function(newPlayer)
			-- Escuchar cuando su personaje aparece
			conexionesResaltarCharAdded[newPlayer] = newPlayer.CharacterAdded:Connect(onCharacterAddedForHighlight)
			-- Escuchar cuando su personaje se va
			table.insert(conexionesActivas, newPlayer.CharacterRemoving:Connect(onCharacterRemovingForHighlight))
		end)
		table.insert(conexionesActivas, conexionResaltarPlayerAdded)

		-- 2. Conectar y aplicar para jugadores *actuales*
		for _, p in pairs(PlayersService:GetPlayers()) do
			if p ~= player then
				-- Aplicar al personaje actual
				if p.Character then
					onCharacterAddedForHighlight(p.Character)
				end
				-- Conectar para respawns
				conexionesResaltarCharAdded[p] = p.CharacterAdded:Connect(onCharacterAddedForHighlight)
				table.insert(conexionesActivas, conexionesResaltarCharAdded[p])
				table.insert(conexionesActivas, p.CharacterRemoving:Connect(onCharacterRemovingForHighlight))
			end
		end
		
	else
		botonOpcion5.Text = "Resaltar"
		botonOpcion5.BackgroundColor3 = Color3.fromRGB(70, 70, 85)

		-- 1. Desconectar PlayerAdded
		if conexionResaltarPlayerAdded then
			conexionResaltarPlayerAdded:Disconnect()
			conexionResaltarPlayerAdded = nil
		end
		
		-- 2. Desconectar todos los listeners de CharacterAdded/Removing
		for player, connection in pairs(conexionesResaltarCharAdded) do
			connection:Disconnect()
		end
		conexionesResaltarCharAdded = {}
		
		-- 3. Limpiar a todos los jugadores actuales
		for _, p in pairs(PlayersService:GetPlayers()) do
			if p.Character then
				for _, descendant in pairs(p.Character:GetDescendants()) do
					aplicarResaltado(descendant, false)
				end
			end
		end
	end
end
